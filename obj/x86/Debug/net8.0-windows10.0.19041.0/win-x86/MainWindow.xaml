<Window x:ConnectionId='1'
    x:Class="TrueReplayerApp2.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TrueReplayerApp2"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:TrueReplayerApp2.Converters"
    mc:Ignorable="d">

    <!-- Grid externo: -->
    <Grid Background="#1e1e1e">
        <Grid.Resources>
            <converters:NonNegativeIntConverter x:Key="NonNegativeIntConverter" />
        </Grid.Resources>

        <!-- Grid interno -->
        <Grid x:ConnectionId='2' 
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch" 
            Padding="12" 
            RowSpacing="12" 
            ColumnSpacing="12" 
                                  >

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock 
                Text="🎮 TrueReplayer" 
                FontSize="24" 
                FontWeight="Bold" 
                Foreground="White" 
                Grid.ColumnSpan="2" />

            <!-- DataGrid -->
            <controls:DataGrid x:ConnectionId='3' 
                x:Name="ActionsDataGrid" 
                Grid.Row="1" 
                Grid.Column="0"
                AutoGenerateColumns="False"
                                                           
                CanUserSortColumns="False"
                CanUserReorderColumns="False"
                HeadersVisibility="All"
                GridLinesVisibility="Vertical"
                BorderThickness="1"
                BorderBrush="Gray"
                RowBackground="#292929"
                AlternatingRowBackground="#1e1e1e"
                Foreground="White"
                Background="#1e1e1e"
                                                 >

                <controls:DataGrid.Columns>
                    <!-- ComboBox para ActionType -->
                    <controls:DataGridComboBoxColumn x:ConnectionId='26' 
                        Header="Action"
                        Width="140"
                        Binding="{Binding ActionType}"
                                                           />

                    <controls:DataGridTextColumn 
                        Header="Key" 
                        Binding="{Binding DisplayKey}" 
                        Width="100"/>

                    <controls:DataGridTextColumn 
                        Header="X" 
                        Binding="{Binding X}" 
                        Width="65"/>

                    <controls:DataGridTextColumn 
                        Header="Y" 
                        Binding="{Binding Y}" 
                        Width="65"/>

                    <controls:DataGridTextColumn 
                        Header="Delay"
                        Binding="{Binding Delay, Converter={StaticResource NonNegativeIntConverter}}"
                        Width="Auto" />

                    <controls:DataGridTextColumn 
                        Header="Comment" 
                        Binding="{Binding Comment}" 
                        Width="2*"/>
                </controls:DataGrid.Columns>
            </controls:DataGrid>

            <!-- Painel de Configurações com rolagem -->
            <Grid Grid.Row="1" Grid.Column="1">
                <!-- ScrollViewer com ScrollBar sempre visível -->
                <ScrollViewer VerticalScrollBarVisibility="Visible">
                    <StackPanel x:ConnectionId='11' x:Name="ConfigPanel" Padding="2">
                        <!-- GRUPO: Settings -->
                        <StackPanel Spacing="2">
                            <TextBlock 
                                Text="⚙️ Settings" 
                                FontSize="18" 
                                FontWeight="SemiBold" 
                                Foreground="White"/>

                            <!-- Delay -->
                            <StackPanel>
                                <TextBlock 
                                    Text="Custom Delay (ms)" 
                                    Foreground="White" 
                                    Margin="0,8"/>
                                <TextBox x:ConnectionId='24' 
                                    x:Name="CustomDelayTextBox" 
                                    Text="100" 
                                                                         
                                                                                   />
                                <ToggleSwitch x:ConnectionId='25' 
                                    x:Name="UseCustomDelaySwitch" 
                                    IsOn="True"/>
                            </StackPanel>

                            <!-- Loop Count -->
                            <StackPanel>
                                <TextBlock 
                                    Text="Loop Count" 
                                    Foreground="White" 
                                    Margin="0,8"/>
                                <TextBox x:ConnectionId='22' 
                                    x:Name="LoopCountTextBox" 
                                    Text="1" 
                                                                       
                                                                                />
                                <ToggleSwitch x:ConnectionId='23' 
                                    x:Name="EnableLoopSwitch" 
                                    IsOn="False"/>
                            </StackPanel>

                            <!-- Loop Interval -->
                            <StackPanel>
                                <TextBlock 
                                    Text="Loop Interval (ms)" 
                                    Foreground="White" 
                                    Margin="0,8"/>
                                <TextBox x:ConnectionId='20' 
                                    x:Name="LoopIntervalTextBox" 
                                    Text="1000" 
                                                                          
                                                                                   />
                                <ToggleSwitch x:ConnectionId='21' 
                                    x:Name="LoopIntervalSwitch" 
                                    IsOn="False"/>
                            </StackPanel>

                            <!-- Bulk Edit Delay -->
                            <StackPanel>
                                <TextBlock 
                                    Text="Bulk Edity" 
                                    Foreground="White" 
                                    Margin="0,8"/>
                                <TextBox x:ConnectionId='19' 
                                    x:Name="BatchDelayTextBox" 
                                    Width="Auto" 
                                    PlaceholderText="Delay (ms)" 
                                                                        
                                                                                 />
                            </StackPanel>
                        </StackPanel>

                        <Rectangle 
                            Height="1" 
                            Fill="Gray" 
                            Opacity="0.3" 
                            Margin="0,8"/>

                        <!-- Grupo: Actions -->
                        <StackPanel Spacing="2">
                            <TextBlock 
                                Text="⚙️ Actions" 
                                FontSize="18" 
                                FontWeight="SemiBold" 
                                Foreground="White"/>
                            <ToggleSwitch x:ConnectionId='16' 
                                x:Name="RecordMouseSwitch" 
                                Header="Record Mouse Clicks" 
                                IsOn="True" 
                                Margin="0,10,0,0"/>
                            <ToggleSwitch x:ConnectionId='17' 
                                x:Name="RecordScrollSwitch" 
                                Header="Record Mouse Scroll" 
                                IsOn="True"/>
                            <ToggleSwitch x:ConnectionId='18' 
                                x:Name="RecordKeyboardSwitch" 
                                Header="Record Keyboard" 
                                IsOn="True"/>
                        </StackPanel>

                        <Rectangle 
                            Height="1" 
                            Fill="Gray" 
                            Opacity="0.3" 
                            Margin="0,8"/>

                        <!-- Grupo: Hotkeys -->
                        <StackPanel Spacing="2">
                            <TextBlock 
                                Text="⚙️ Hotkeys" 
                                FontSize="18" 
                                FontWeight="SemiBold" 
                                Foreground="White"/>

                            <StackPanel>
                                <TextBlock 
                                    Text="Start/Pause Recording" 
                                    Foreground="White" 
                                    Margin="0,8"/>
                                <TextBox x:ConnectionId='15' 
                                    x:Name="ToggleRecordingTextBox" 
                                    Width="Auto" 
                                    IsReadOnly="True" 
                                                                                  />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock 
                                    Text="Start/Stop Replay" 
                                    Foreground="White" 
                                    Margin="0,8"/>
                                <TextBox x:ConnectionId='14' 
                                    x:Name="ToggleReplayTextBox" 
                                    Width="Auto" 
                                    IsReadOnly="True" 
                                                                                  />
                            </StackPanel>
                        </StackPanel>

                        <Rectangle 
                            Height="1" 
                            Fill="Gray" 
                            Opacity="0.3" 
                            Margin="0,10,0,0"/>

                        <StackPanel>
                            <ToggleSwitch x:ConnectionId='12' 
                                x:Name="MinimizeToTraySwitch" 
                                Header="Minimize to Tray" 
                                IsOn="True" 
                                Margin="0,5,0,0"/>
                            <ToggleSwitch x:ConnectionId='13' 
                                x:Name="AlwaysOnTopSwitch"
                                Header="Always on Top"
                                IsOn="True"
                                                                   
                                Margin="0,8,0,0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border 
                    Height="30" 
                    VerticalAlignment="Bottom" 
                    IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0.0" Color="#00000000"/>
                            <!-- transparente -->
                            <GradientStop Offset="2.0" Color="#88FFFFFF"/>
                            <!-- branco semi-transparente -->
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>

            <!-- Botões -->
            <StackPanel 
                Grid.Row="2" 
                Grid.Column="0" 
                Grid.ColumnSpan="2" 
                Orientation="Horizontal" 
                HorizontalAlignment="Left" 
                Spacing="1">
                <Button x:ConnectionId='5' 
                    x:Name="RecordingButton" 
                    Content="Recording" 
                    Width="100" 
                    Margin="1" 
                                                  
                    Padding="1,8" />
                <Button x:ConnectionId='6' 
                    x:Name="ReplayButton" 
                    Content="Replay" 
                    Width="100" 
                    Margin="1" 
                                               
                    Padding="1,8" />
                <Button x:ConnectionId='7' 
                    x:Name="ClearButton" 
                    Content="Clear" 
                    Width="65" 
                    Margin="1" 
                                              
                    Padding="1,8" />
                <Button x:ConnectionId='8' 
                    x:Name="CopyButton" 
                    Content="Copy" 
                    Width="65" 
                    Margin="1" 
                                             
                    Padding="1,8" />
                <Button x:ConnectionId='9' 
                    x:Name="SaveButton" 
                    Content="Save" 
                    Width="65" 
                    Margin="1" 
                                             
                    Padding="1,8" />
                <Button x:ConnectionId='10' 
                    x:Name="LoadButton" 
                    Content="Load" 
                    Width="65" 
                    Margin="1" 
                                             
                    Padding="1,8" />
            </StackPanel>

            <!-- ResetButton -->
            <StackPanel 
                Grid.Row="2" 
                Grid.Column="0" 
                Grid.ColumnSpan="2" 
                Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                Spacing="1">
                <Button x:ConnectionId='4' 
                    x:Name="ResetButton" 
                    Content="Reset Settings" 
                    Width="110" 
                    Margin="1" 
                                              
                    Padding="1,8" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

